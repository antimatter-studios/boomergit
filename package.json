{
  "name": "boomergit",
  "displayName": "BoomerGit",
  "description": "Old man shakes stick at crap git integrations — native git graph visualization",
  "version": "0.3.2",
  "publisher": "ChristopherThomas",
  "icon": "resources/old_man_yells_at_git_256.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/antimatter-studios/boomergit"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "resourceLabelFormatters": [
      {
        "scheme": "boomergit-file",
        "formatting": {
          "label": "${path} (${query.label})",
          "separator": "/",
          "stripPathStartingSeparator": true
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "boomergit-sidebar",
          "title": "BoomerGit",
          "icon": "resources/boomergit-icon.svg"
        }
      ]
    },
    "views": {
      "boomergit-sidebar": [
        {
          "id": "boomergit.welcome",
          "name": "BoomerGit",
          "when": "!boomergit:graphOpen"
        },
        {
          "id": "boomergit.commitInfo",
          "name": "Commit Info",
          "type": "webview",
          "when": "boomergit:graphOpen"
        },
        {
          "id": "boomergit.changedFiles",
          "name": "Changed Files",
          "when": "boomergit:graphOpen"
        }
      ]
    },
    "languages": [
      {
        "id": "boomergit",
        "aliases": [
          "BoomerGit Graph"
        ]
      }
    ],
    "commands": [
      {
        "command": "boomergit.showGraph",
        "title": "BoomerGit: Show Graph"
      },
      {
        "command": "boomergit.checkoutRef",
        "title": "Checkout Ref"
      },
      {
        "command": "boomergit.deleteBranch",
        "title": "Delete Branch"
      },
      {
        "command": "boomergit.createBranch",
        "title": "Create Branch"
      },
      {
        "command": "boomergit.copyText",
        "title": "Copy Text"
      },
      {
        "command": "boomergit.openFileDiff",
        "title": "Show File Diff"
      },
      {
        "command": "boomergit.selectUp",
        "title": "Select Previous Row"
      },
      {
        "command": "boomergit.selectDown",
        "title": "Select Next Row"
      },
      {
        "command": "boomergit.refresh",
        "title": "BoomerGit: Refresh Graph",
        "icon": "$(refresh)"
      },
      {
        "command": "boomergit.toggleAutoRefresh",
        "title": "BoomerGit: Toggle Auto-Refresh"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "boomergit.refresh",
          "when": "resourceScheme == boomergit",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "boomergit.checkoutRef",
          "when": "false"
        },
        {
          "command": "boomergit.deleteBranch",
          "when": "false"
        },
        {
          "command": "boomergit.createBranch",
          "when": "false"
        },
        {
          "command": "boomergit.copyText",
          "when": "false"
        },
        {
          "command": "boomergit.openFileDiff",
          "when": "false"
        },
        {
          "command": "boomergit.selectUp",
          "when": "false"
        },
        {
          "command": "boomergit.selectDown",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "boomergit.selectUp",
        "key": "up",
        "when": "resourceScheme == boomergit && editorTextFocus"
      },
      {
        "command": "boomergit.selectDown",
        "key": "down",
        "when": "resourceScheme == boomergit && editorTextFocus"
      }
    ],
    "configurationDefaults": {
      "[boomergit]": {
        "editor.lineHeight": 1.8,
        "editor.contextmenu": false,
        "editor.hover.above": false,
        "editor.minimap.enabled": false,
        "editor.scrollBeyondLastLine": false,
        "editor.hover.delay": 100,
        "editor.multiCursorModifier": "ctrlCmd",
        "editor.cursorStyle": "underline-thin",
        "editor.cursorBlinking": "solid",
        "editor.cursorWidth": 0,
        "editor.occurrencesHighlight": "off",
        "editor.selectionHighlight": false,
        "editor.renderLineHighlight": "none"
      }
    },
    "configuration": {
      "title": "BoomerGit",
      "properties": {
        "boomergit.autoRefresh": {
          "type": "boolean",
          "default": false,
          "description": "Automatically refresh the graph when the repository's refs change (watches .git). Toggle from the status bar while the graph is open."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && mkdir -p build && vsce package --out build/",
    "publish:vscode": "vsce publish --packagePath build/boomergit-*.vsix",
    "publish:openvsx": "ovsx publish build/boomergit-*.vsix",
    "publish:all": "npm run publish:vscode && npm run publish:openvsx",
    "release:patch": "node scripts/release-prepare.mjs patch",
    "release:minor": "node scripts/release-prepare.mjs minor",
    "release:major": "node scripts/release-prepare.mjs major"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "ovsx": "^0.10.9",
    "typescript": "^5.3.0",
    "vitest": "^4.1.9"
  }
}
